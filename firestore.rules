rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /consultas/{consultaId} {
      allow read: if true;

      // Criação: somente o estado inicial "marcada" é permitido
      allow create: if request.resource.data.situacao == 'marcada';

      // Atualização: apenas transições de estado definidas no domínio são permitidas
      allow update: if isTransicaoValida(
        resource.data.situacao,
        request.resource.data.situacao
      );

      allow delete: if false;
    }

    // Espelha o mapa de transições de consultaStateMachine.ts
    function isTransicaoValida(de, para) {
      return
        (de == 'marcada' && para in ['confirmada', 'canceladaPeloCliente', 'canceladaPeloMedico', 'canceladaPorNaoComparecimento'])
        || (de == 'confirmada' && para in ['realizada', 'canceladaPeloCliente', 'canceladaPeloMedico', 'canceladaPorNaoComparecimento'])
        || (de == 'realizada' && para == 'encerrada')
        || (de == 'canceladaPorNaoComparecimento' && para == 'marcada');
    }
  }
}
